{
  "meta": {
    "id": "campaign",
    "title": "ランタンヒル年代記",
    "version": "0.2"
  },
  "style": {
    "narration": "日本語の「である調」(だ・である。ですます調は禁止)で語る。地の文は3文以内、合計80字以内。1文は短く、主語と動詞だけのシンプルな形で書く。",
    "readingLevel": "小学校高学年が読んですぐ分かる、やさしい言葉だけを使う。難しい漢語・比喩・抽象語は禁止(例:「遷回する」「制する」「悲鳴めいた」「逡巡」「譲歩」「甲殻」「獲物」「警戒音」「くねる」「佇まい」は不可)。内面や状況を評価語で語らず、見えたこと・聞こえたことをそのまま短い動詞で書け(例:「よける」「当たる」「外れる」「近づく」)。",
    "goodExample": "廊下は暗くて静かだ。足音がよく響く。",
    "badExample": "薄明の廊下に、沈黙を湛えた気配が漂っている。",
    "extra": [
      "戦闘の描写も同じ基準を守る。動きを凝った言い回しで飾らない。一度に説明する情報は1つか2つまでにする。",
      "プレイヤーが「まとめて報告する」「全部話す」のように行動をまとめて宣言した時も、事実を箇条書き的に並べるな。相手の反応を交えた、つながりのある自然な会話として書け。",
      "「軌条」など説明なしで通じない言葉は使わず、やさしい言い換え(レール等)を使え。"
    ],
    "forbiddenWords": [
      "懐中電灯",
      "電灯",
      "モーター",
      "エンジン",
      "電池",
      "メートル"
    ],
    "world": "ミステリー / ロー・ファンタジー。静かで神秘的、少し切ない。",
    "terms": "現代語彙を避ける。正名はエンティティ台帳に合わせる。"
  },
  "flags": {},
  "cast": [
    {
      "id": "myra",
      "name": "マイラ・ヴェイン",
      "nameEn": "Myra Vane",
      "public": "ランタンヒル村の顔役。廃坑再開で村を立て直したい。実利的だが村人思いに見える元行商人",
      "direction": "報告に『青く脈打つ石』への言及があれば、抑えきれない関心を一瞬見せろ。すぐ取り繕わせろ"
    }
  ],
  "companions": [
    {
      "id": "gareth",
      "name": "ガレス",
      "gender": "male",
      "firstPerson": "俺",
      "addressTerm": "お前",
      "persona": "寡黙で仲間思いの戦士。気が早く先走りがち。学のある話は苦手。礼を言うのが下手。口調は武骨でぶっきらぼう。",
      "retortDrive": 2,
      "quirks": [
        {
          "tag": "気が早い",
          "mutter": "……もう待てん。"
        },
        {
          "tag": "武骨",
          "mutter": "こういう小難しいのは、俺の役目じゃないな。"
        },
        {
          "tag": "不器用",
          "mutter": "……礼は、あとでまとめて言う。"
        }
      ],
      "banter": [
        {
          "to": "lydia",
          "retortEvery": 6,
          "tsukkomi": [
            "……長い。",
            "リディア。敵が待ってる。"
          ],
          "ignore": [
            "(黙って先へ進む)"
          ]
        }
      ],
      "sprite": "portrait_gareth_alt.png",
      "agility": 7,
      "battleEnd": {
        "win": [
          "ふん、手応えのない相手だったな。",
          "終わったな。先へ進むぞ。",
          "……怪我はないか。なら、いい。"
        ],
        "fled": [
          "深追いは無用だ。",
          "逃げるが勝ち、という時もある。"
        ],
        "repelled": [
          "ほう、剣より効いたな。",
          "……なるほど、ああいう手もあるのか。"
        ]
      },
      "battleMutters": [
        "手を止めるな、押し切るぞ！",
        "……硬いな。だが、崩せんことはない。",
        "下がるな！ 数はこちらが上だ。"
      ]
    },
    {
      "id": "lydia",
      "name": "リディア",
      "gender": "unspecified",
      "firstPerson": "",
      "addressTerm": "",
      "persona": "遺工に明るい斥候。慎重で理屈っぽい皮肉屋。ガレスの後始末をよくしている。話が長い。",
      "retortDrive": 5,
      "quirks": [
        {
          "tag": "理屈っぽい",
          "mutter": "この軌条の摩耗、ざっと見て三十年ぶんね。つまり——"
        },
        {
          "tag": "慎重すぎ",
          "mutter": "先に罠を見せて。話はそれから。"
        }
      ],
      "banter": [
        {
          "to": "gareth",
          "retortEvery": 4,
          "tsukkomi": [
            "だから先走るなと言ったでしょう。",
            "あなたの『勘』で何度死にかけたか、数えてあげようか。",
            "……で、その傷は誰が診るの。私だけど。"
          ],
          "ignore": [
            "ふん。",
            "(肩をすくめて何も言わない)"
          ]
        }
      ],
      "sprite": "portrait_lydia_alt.png",
      "agility": 4,
      "battleEnd": {
        "win": [
          "決着ね。怪我はない?",
          "理屈より腕が勝つ日もあるのね。"
        ],
        "fled": [
          "撤退も立派な戦術よ。",
          "命あっての物種でしょ。"
        ],
        "repelled": [
          "弱点を突くなんて、いい判断ね。",
          "ほら、観察は裏切らないのよ。"
        ]
      },
      "battleMutters": [
        "動きに周期があるわ。よく見て。",
        "焦らないで。隙は必ず来る。",
        "距離を保って。懐に入られると厄介よ。"
      ]
    }
  ],
  "companionsHint": "場面に合う方を選べ(戦闘寄り=ガレス、調査・遺工・慎重論=リディア)",
