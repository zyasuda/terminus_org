  "companions": [
    {
      "id": "gareth",
      "name": "ガレス",
      "persona": "寡黙で実用的な戦士。短く話す。",
      "sprite": "portrait_gareth_alt.png",
      "gender": "male",
      "firstPerson": "俺",
      "addressing": "お前",
      "addressTerm": "お前"
    },
    {
      "id": "lydia",
      "name": "リディア",
      "persona": "遺工に明るい斥候。慎重で理屈っぽい皮肉屋。ガレスの後始末をよくしている。話が長い。",
      "retortDrive": 5,
      "quirks": [
        {"tag": "理屈っぽい", "mutter": "この軌条の摩耗、ざっと見て三十年ぶんね。つまり——"},
        {"tag": "慎重すぎ", "mutter": "先に罠を見せて。話はそれから。"}
      ],
      "banter": [
        {
          "to": "gareth",
          "retortEvery": 4,
          "tsukkomi": [
            "だから先走るなと言ったでしょう。",
            "あなたの『勘』で何度死にかけたか、数えてあげようか。",
            "……で、その傷は誰が診るの。私だけど。"
          ],
          "ignore": ["ふん。", "(肩をすくめて何も言わない)"]
        }
      ],
      "sprite": "portrait_lydia_alt.png",
      "agility": 4,
      "battleEnd": {
        "win": ["決着ね。怪我はない?", "理屈より腕が勝つ日もあるのね。"],
        "fled": ["撤退も立派な戦術よ。", "命あっての物種でしょ。"],
        "repelled": ["弱点を突くなんて、いい判断ね。", "ほら、観察は裏切らないのよ。"]
      }
    }
  ],
