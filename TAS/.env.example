# LLM設定（使うバックエンドのキーだけ設定してください）
LLM_BACKEND=gemini
GEMINI_API_KEY=
LLM_MODEL=gemini-2.5-flash

# 任意: ディレクトリ構成が標準（Terminus/TAS と Terminus/trpg-gm-mock2）の場合は不要です。
# 相対パスはTASフォルダ基準、絶対パスも指定できます。
MOCK2_DIR=../trpg-gm-mock2
MOCKDOCS_DIR=
# CAMPAIGN_OUTPUT_DIR=../trpg-gm-mock2/public/data
# MOCK_IMAGES_DIR=../trpg-gm-mock2/images
# TAS_OUTPUT_DIR=output

# 任意: ポート番号
# PORT=8799
